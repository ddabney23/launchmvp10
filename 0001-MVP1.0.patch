 // Check if we're running on the server or client
 const isServer = typeof window === 'undefined'
 
+/** Treat template/placeholder env values as unset so optional URL fields do not fail builds. */
+function envPlaceholderToUndefined(value: unknown): unknown {
+  if (typeof value !== 'string') return value
+  const trimmed = value.trim()
+  if (
+    trimmed === '' ||
+    /^YOUR_/i.test(trimmed) ||
+    /_HERE$/i.test(trimmed) ||
+    /^your[-_]/i.test(trimmed)
+  ) {
+    return undefined
+  }
+  return value
+}
+
+const optionalUrl = () =>
+  z.preprocess(envPlaceholderToUndefined, z.string().url().optional())
+
 // Client-side schema (only NEXT_PUBLIC_ vars are available in browser)
 const clientEnvSchema = z.object({
   NEXT_PUBLIC_SUPABASE_URL: z.string().url('Must be a valid URL'),
   NEXT_PUBLIC_SUPABASE_ANON_KEY: z.string().min(1, 'Cannot be empty'),
-  NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME: z.string().optional(),
-  NEXT_PUBLIC_SENTRY_DSN: z.string().url().optional(),
-  NEXT_PUBLIC_STRIPE_PUBLIC_KEY: z.string().optional(),
-  NEXT_PUBLIC_APP_URL: z.string().url().optional(),
-  NEXT_PUBLIC_REALTIME_SERVER_URL: z.string().url().optional(),
-  NEXT_PUBLIC_VAPID_PUBLIC_KEY: z.string().optional(),
-  NEXT_PUBLIC_TELEMETRY_URL: z.string().url().optional(),
+  NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME: z.preprocess(envPlaceholderToUndefined, z.string().optional()),
+  NEXT_PUBLIC_SENTRY_DSN: optionalUrl(),
+  NEXT_PUBLIC_STRIPE_PUBLIC_KEY: z.preprocess(envPlaceholderToUndefined, z.string().optional()),
+  NEXT_PUBLIC_APP_URL: optionalUrl(),
+  NEXT_PUBLIC_REALTIME_SERVER_URL: optionalUrl(),
+  NEXT_PUBLIC_VAPID_PUBLIC_KEY: z.preprocess(envPlaceholderToUndefined, z.string().optional()),
+  NEXT_PUBLIC_TELEMETRY_URL: optionalUrl(),
   NEXT_PUBLIC_TELEMETRY_ENABLED: z.string().optional(),
   NEXT_PUBLIC_STRIPE_PRICE_FREE: z.string().optional(),
   NEXT_PUBLIC_STRIPE_PRICE_BASIC: z.string().optional(),
@@ -25,8 +43,8 @@ const clientEnvSchema = z.object({
 
 // Server-side schema (includes all variables)
